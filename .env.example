# Скопируй в .env (вне репо). Секреты — в ./secrets/* как Docker secrets,
# НЕ сюда. Здесь только несекретная конфигурация.

# Кому отвечает бот (owner-allowlist, критично). Узнать ID: @userinfobot.
TELEGRAM_ALLOWED_USER_ID=0

# Vault MCP на Desktop (LAN, через Caddy). Проверено: 192.168.1.50:8788.
MCP_URL=http://192.168.1.50:8788/mcp

# LLM через apinet (egress идёт через singbox-прокси из docker-compose).
# База — Sonnet 4.6; тяжёлые задачи — та же модель с extended thinking.
CLAUDE_BASE_URL=https://apinet.cloud/v1
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_THINKING_MODEL=claude-sonnet-4-6-thinking

# Mini App «Граф»: внешний HTTPS-адрес просмотрщика (Caddy на kojikk-server).
# Пусто = /graph отключён. Порт сервера внутри контейнера — GRAPH_PORT (8090).
GRAPH_PUBLIC_URL=https://brain.kojikk.ru:8443

# Прочее
TIMEZONE=Europe/Moscow
MONTHLY_BUDGET_USD=50
USAGE_SOURCE=estimate

# --- секреты кладутся файлами (Docker secrets), а не сюда: ---
#   ./secrets/mcp_token        (= содержимое C:\Projects\obsidian-mcp\secrets\mcp_token, 64 hex)
#   ./secrets/telegram_token   (токен бота от @BotFather)
#   ./secrets/claude_api_key   (ключ apinet)
